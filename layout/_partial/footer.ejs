<footer id="footer">
  <div class="footer-left">
    &hearts;
    <%= config.author %>:
    <% var endYear = (theme.copyright && theme.copyright.end_year) ? theme.copyright.end_year : new Date().getFullYear() %>
    <% var startYear = (theme.copyright && theme.copyright.start_year) ? theme.copyright.start_year : new Date().getFullYear() %>
    <%= startYear >= endYear ? endYear : startYear + "-" + endYear %>
    &hearts;
  </div>
  <div class="footer-right">
    <nav>
      <ul>
        <% for (var i in theme.nav) { %><!--
       --><li><a href="<%- url_for(theme.nav[i]) %>"><%= __('nav.'+i).replace("nav.", "") %></a></li><!--
     --><% } %>
      </ul>
    </nav>
  </div>
  <div style="text-align: center;">
    <span id="busuanzi_container_page_pv">本文总阅读 <span id="busuanzi_value_page_pv"></span> 次</span>
    |
    <span id="busuanzi_container_site_uv">本站总访问量 <span id="busuanzi_value_site_uv"></span> 人</span>
    /
    <span id="busuanzi_container_site_pv"><span id="busuanzi_value_site_pv"></span> 次</span>
    <script>
      fetch('https://busuanzi.neolux.eu.org/')
        .then(function (res) { return res.json() })
        .then(function (data) {
          var siteUv = document.getElementById('busuanzi_value_site_uv')
          var sitePv = document.getElementById('busuanzi_value_site_pv')
          var pagePv = document.getElementById('busuanzi_value_page_pv')

          if (siteUv && data.site_uv !== undefined) {
            siteUv.innerText = data.site_uv
          }

          if (sitePv && data.site_pv !== undefined) {
            sitePv.innerText = data.site_pv
          }

          if (pagePv && data.page_pv !== undefined) {
            pagePv.innerText = data.page_pv
          }
        })
        .catch(function (err) {
          console.error('Failed to fetch busuanzi stats:', err)
        })
    </script>
  </div>
</footer>
